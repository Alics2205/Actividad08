public class Guerrero extends Personaje {

    private String arma;

    // Constructor
    public Guerrero(String nombre, int nivel, int hp, int ataque, String arma) {

        super(nombre, nivel, hp, ataque);
        this.arma = arma;
    }

    // Atacar a otro personaje
    public void atacar(Personaje enemigo) {

        System.out.println(nombre + " ataca a " + enemigo.nombre + " con su " + arma + "!");
        enemigo.recibirDanio(getAtaque());
        System.out.println(enemigo.nombre + " recibió " + getAtaque() + " de daño.");
    }

    // Sobrescribir mostrarInfo
    @Override
    public void mostrarInfo() {

        super.mostrarInfo();
        System.out.println("Arma: " + arma);
    }

}
